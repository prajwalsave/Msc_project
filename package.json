{
  "name": "cesium-transit",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "server": "tsx server/index.ts",
    "dev:all": "concurrently -n \"VITE,SERVER\" -c \"magenta,blue\" \"npm run dev\" \"npm run server\"",
    "clean": "rimraf dist dist-server"
  },
  "dependencies": {
    "axios": "^1.10.0",
    "cesium": "^1.131.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^7.0.4",
    "vite-plugin-cesium": "^1.2.23",
    "vite-plugin-static-copy": "^3.1.0"
  }
}
