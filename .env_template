# Cesium ION Token - Required for map tiles
# Obtain at: https://ion.cesium.com/tokens
VITE_CESIUM_ION_TOKEN='your_cesium_ion_token_here'

# Google Maps API Key - Required for Photorealistic 3D Tiles
# Obtain at: https://console.cloud.google.com/google/maps-apis/credentials
VITE_GOOGLE_MAPS_API_KEY='your_google_maps_api_key_here'

# OpenAQ API Key - Required for live air quality data
# Obtain at: https://openaq.org/ (via API dashboard)
OPENAQ_API_KEY='your_openaq_api_key_here'

# Express Server Port
PORT=5055
